# ─────────────────────────────────────────────────────────────────────────────
# Production .env example for sanctum / Jeff Studio POS.
# Copy to .env on the server, fill in real values, never commit.
# All vars are read by both the postgres init script and the Next.js app.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres container ──────────────────────────────────────────────────────
# Created by the official postgres:16-alpine image at first boot.
POSTGRES_DB=sanctum
POSTGRES_USER=sanctum_admin
POSTGRES_PASSWORD=change-me-superuser

# Least-privileged app role (created by postgres/init/01-app-user.sh).
# This is what DATABASE_URL below must point to. Keep the superuser above
# for migrations and emergency operations only.
POSTGRES_APP_USER=sanctum_app
POSTGRES_APP_PASSWORD=change-me-app

# Container timezone — keeps logs and timestamps aligned with Bogotá ops.
TZ=America/Bogota

# ── Next.js app ─────────────────────────────────────────────────────────────
NODE_ENV=production

# Host name "postgres" matches the service name in docker-compose.prod.yml,
# resolved via the sanctum_private_net bridge network.
DATABASE_URL=postgres://sanctum_app:change-me-app@postgres:5432/sanctum

# Better Auth: secret MUST be a strong random string (≥32 chars).
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=https://admin.sanctum.tattoo
BETTER_AUTH_TRUSTED_ORIGINS=https://admin.sanctum.tattoo

# ── First-time bootstrap (used by `bun run bootstrap:prod`) ─────────────────
# Required only on the very first deploy. After the owner exists you can
# unset these. Idempotent: re-running with the same values is a no-op.
BOOTSTRAP_OWNER_EMAIL=jeff@sanctum.tattoo
BOOTSTRAP_OWNER_PASSWORD=change-me-strong-password
BOOTSTRAP_OWNER_NAME=Jeff
BOOTSTRAP_BUSINESS_NAME=Sanctum Tattoo
BOOTSTRAP_BUSINESS_SLUG=sanctum
BOOTSTRAP_LOCATIONS=amparo:Amparo,britalia:Britalia
